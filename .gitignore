## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/
.vscode/
.idea/

# Visual Studio Code
.vs/
.vscode/

# JetBrains Rider
.idea/
*.sln.iml

# NuGet Packages
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/
*.nuget.props
*.nuget.targets

# Enable uncommenting to ignore the global_utils folder in the repo root
# global_utils/

# Enable uncommenting to ignore the node_modules folder in the repo root
# node_modules/

# Database files
*.mdf
*.ldf
*.ndf
*.sqlite
*.db

# Entity Framework Core
# Uncomment if you have generated migrations
# Migrations/

# Build results of .NET projects
**/bin/
**/obj/
**/out/
**/publish/

# Files built by Visual Studio
*_i.c
*_p.c
*_h.h
*.ilk
*.meta
*.obj
*.iobj
*.pch
*.pdb
*.ipdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*_wpftmp.csproj
*.log
*.vspscc
*.vsscc
.builds
*.pidb
*.svclog
*.scc

# Files generated by unit test runners
*.VisualState.xml
TestResults/
*.coverage
*.coveragexml
*.testresults
xunit.runner.utility/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# StyleCop
StyleCopReport.xml

# Rider
.idea/
*.DotSettings.user

# Resharper
_ReSharper.*
*.ReSharper.*
*.DotSettings

# Visual Studio cache
.vs/

# Uncomment if you have packages that you don't want to commit
packages/

# Enable uncommenting if you have SQL Server database project files
# *.sqlproj

# Enable uncommenting if you have web.config transformations
# *.Transform.web.config

# Enable uncommenting if you have web deploy package
# *.Package.zip
# *.Publish.xml

# Windows Store app package
*.appx
*.appxbundle
*.appxupload

# Visual Studio cache files
.vs/

# Uncomment if you have Visual Studio IntelliTrace files
# *.iTrace

# Enable uncommenting if you have Visual Studio 2017 auto-generated files
# Generated Files/

# Enable uncommenting if you have Visual Studio 2015+ auto-generated files
# Generated Files/

# Files that might appear in the root of a project
# ProjectLock.json
# .DS_Store
# Thumbs.db
# ehthumbs.db
# Desktop.ini

